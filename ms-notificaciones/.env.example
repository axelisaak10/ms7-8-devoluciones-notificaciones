# En modo de prueba, Resend solo admite como destino el correo de la cuenta que creó la API key.
RESEND_API_KEY=reemplazar
RESEND_FROM=Biblioteca UTEQ <onboarding@resend.dev>
RESEND_TEST_MODE=true
RESEND_TEST_RECIPIENT=tu-correo-de-la-cuenta-resend@example.com
RESEND_MAX_ATTEMPTS=3

# Secretos de cliente OAuth definidos también en ms-user-auth-register/.env
MS_NOTIFICATIONS_CLIENT_ID=ms-notificaciones-service
MS_NOTIFICATIONS_CLIENT_SECRET=reemplazar
